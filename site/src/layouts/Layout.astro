---
interface Props {
  title?: string;
  description?: string;
}
const { title = "Copilot Extensions", description = "An Astro site on GitHub Pages." } = Astro.props;

// `base` already ends in a slash (e.g. "/repo/" or "/"), so concatenating a
// bare path produces a correct, base-aware URL.
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>
    <!-- No-flash theme, applied before first paint. -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme") ||
            (matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
          document.documentElement.setAttribute("data-theme", t);
        } catch (e) {}
      })();
    </script>
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #0d1117; --panel: #161b22; --border: #30363d;
        --fg: #e6edf3; --muted: #9198a1; --accent: #2f81f7;
      }
      :root[data-theme="light"] {
        color-scheme: light;
        --bg: #fff; --panel: #f6f8fa; --border: #d0d7de;
        --fg: #1f2328; --muted: #59636e; --accent: #0969da;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: var(--bg); color: var(--fg);
        font: 16px/1.6 -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        transition: background 0.2s, color 0.2s;
      }
      a { color: var(--accent); }
      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.9em;
        background: color-mix(in srgb, var(--accent) 12%, transparent);
        padding: 0.1em 0.4em; border-radius: 6px;
      }
      .topbar {
        display: flex; align-items: center; gap: 1rem;
        padding: 0.6rem clamp(1rem, 4vw, 2rem); border-bottom: 1px solid var(--border);
        position: sticky; top: 0; z-index: 10;
        background: color-mix(in srgb, var(--bg) 88%, transparent);
        -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
      }
      .brand { font-weight: 700; text-decoration: none; color: var(--fg); }
      .topnav { display: flex; gap: 1rem; margin-left: 0.5rem; }
      .topnav a { color: var(--muted); text-decoration: none; font-weight: 500; }
      .bar-actions { margin-left: auto; display: flex; gap: 0.4rem; align-items: center; }
      .icon-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; border-radius: 9px; border: 1px solid var(--border);
        background: var(--panel); color: var(--fg); cursor: pointer; text-decoration: none;
      }
      .icon-btn:hover { border-color: var(--accent); }
      .wrap { max-width: 880px; margin: 0 auto; padding: clamp(2rem, 6vw, 5rem) 1.25rem; }
      .card-media {
        aspect-ratio: 16 / 9; background: var(--bg);
        border-bottom: 1px solid var(--border); overflow: hidden;
      }
      .card-media img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.35s ease; }
      .card:hover .card-media img, .card:focus-visible .card-media img { transform: scale(1.12); }
      .copy-btn {
        margin-top: 0.5rem; align-self: flex-start;
        display: inline-flex; align-items: center; gap: 0.4rem;
        font: inherit; font-size: 0.85rem; font-weight: 600;
        color: var(--fg); background: var(--bg);
        border: 1px solid var(--border); border-radius: 8px;
        padding: 0.4rem 0.7rem; cursor: pointer;
        transition: border-color 0.15s, color 0.15s, background 0.15s;
      }
      .copy-btn:hover { border-color: var(--accent); color: var(--accent); }
      .copy-btn.copied { border-color: var(--accent); color: var(--accent); }
      .copy-icon { flex: none; }

      /* clickable cards */
      .card {
        background: var(--panel); border: 1px solid var(--border);
        border-radius: 12px; overflow: hidden;
        display: flex; flex-direction: column; cursor: pointer;
        transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
      }
      .card:hover {
        transform: translateY(-3px);
        border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
        box-shadow: 0 12px 32px -14px rgba(0, 0, 0, 0.55);
      }
      .card:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

      /* grouped sections */
      .group { margin-top: 2.75rem; }
      .group:first-of-type { margin-top: 0; }
      .group-head { margin-bottom: 1rem; }
      .group-title { margin: 0; font-size: 1.15rem; display: flex; align-items: center; gap: 0.5rem; }
      .group-count {
        font-size: 0.72rem; font-weight: 600; color: var(--muted);
        background: var(--bg); border: 1px solid var(--border);
        border-radius: 999px; padding: 0.05em 0.55em;
      }
      .group-blurb { margin: 0.35rem 0 0; color: var(--muted); font-size: 0.95rem; }
      .grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
      .grid.grid-solo { grid-template-columns: minmax(0, 360px); }

      /* lightbox */
      .lb-overlay {
        position: fixed; inset: 0; z-index: 50;
        display: flex; align-items: center; justify-content: center;
        padding: clamp(0.75rem, 3vw, 2rem);
        background: rgba(1, 4, 9, 0.72);
        -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px);
        animation: lb-fade 0.18s ease;
      }
      .lb-overlay[hidden] { display: none; }
      .lb-modal {
        position: relative; width: 100%; max-width: 760px; max-height: 90vh;
        overflow: auto; background: var(--panel); border: 1px solid var(--border);
        border-radius: 16px; box-shadow: 0 24px 60px -20px rgba(0, 0, 0, 0.7);
        animation: lb-pop 0.2s ease;
      }
      .lb-media { aspect-ratio: 16 / 9; background: var(--bg); border-bottom: 1px solid var(--border); }
      .lb-media img { width: 100%; height: 100%; object-fit: cover; display: block; transition: opacity 0.15s ease; }
      .lb-body { padding: clamp(1rem, 3vw, 1.5rem); display: flex; flex-direction: column; gap: 0.75rem; }
      .lb-head { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
      .lb-title { margin: 0; font-size: 1.35rem; }
      .lb-badge {
        font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;
        color: var(--accent); background: color-mix(in srgb, var(--accent) 12%, transparent);
        padding: 0.15em 0.55em; border-radius: 999px;
      }
      .lb-desc { margin: 0; color: var(--muted); }
      .lb-install { display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem; }
      .lb-install code { flex: 1 1 240px; overflow-wrap: anywhere; }
      .lb-install .copy-btn { margin-top: 0; }
      .lb-footer { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; flex-wrap: wrap; }
      .lb-gh { text-decoration: none; font-weight: 600; }
      .lb-count { color: var(--muted); font-size: 0.9rem; font-variant-numeric: tabular-nums; }
      .lb-close {
        position: absolute; top: 0.6rem; right: 0.6rem; z-index: 2;
        display: inline-flex; align-items: center; justify-content: center;
        width: 2rem; height: 2rem; border-radius: 999px; cursor: pointer; color: #fff;
        background: rgba(1, 4, 9, 0.55); border: 1px solid rgba(255, 255, 255, 0.18);
      }
      .lb-close:hover { background: rgba(1, 4, 9, 0.85); }
      .lb-nav {
        position: fixed; top: 50%; transform: translateY(-50%); z-index: 51;
        display: inline-flex; align-items: center; justify-content: center;
        width: 2.75rem; height: 2.75rem; border-radius: 999px; cursor: pointer;
        font-size: 1.6rem; line-height: 1; color: #fff;
        background: rgba(1, 4, 9, 0.55); border: 1px solid rgba(255, 255, 255, 0.18);
        transition: background 0.15s ease;
      }
      .lb-nav:hover { background: rgba(1, 4, 9, 0.85); }
      .lb-prev { left: clamp(0.5rem, 2vw, 1.5rem); }
      .lb-next { right: clamp(0.5rem, 2vw, 1.5rem); }

      @keyframes lb-fade { from { opacity: 0; } to { opacity: 1; } }
      @keyframes lb-pop { from { opacity: 0; transform: scale(0.97); } to { opacity: 1; transform: scale(1); } }
      @media (prefers-reduced-motion: reduce) {
        body { transition: none; }
        .lb-overlay, .lb-modal { animation: none; }
        .lb-media img { transition: none; }
        .card { transition: none; }
        .card:hover { transform: none; }
        .card-media img { transition: none; }
        .card:hover .card-media img, .card:focus-visible .card-media img { transform: none; }
      }
    </style>
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href={base}>Copilot Extensions</a>
      <nav class="topnav">
        <a href={base}>Home</a>
        <a href={`${base}about/`}>About</a>
      </nav>
      <div class="bar-actions">
        <button id="theme-toggle" class="icon-btn" type="button" aria-label="Toggle color theme" title="Toggle theme"></button>
        <a class="icon-btn" href="https://github.com/jongio/copilot-extensions" target="_blank" rel="noopener" aria-label="View source on GitHub" title="View source on GitHub">
          <svg viewBox="0 0 16 16" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path></svg>
        </a>
      </div>
    </header>
    <div class="wrap">
      <slot />
      <footer style="margin-top: 3.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border); text-align: center; color: var(--muted); font-size: 0.9rem;">
        Copilot Extensions by
        <a href="https://github.com/jongio" target="_blank" rel="noopener" style="font-weight: 600;">Jon Gallant (jongio)</a>
        · MIT licensed
      </footer>
    </div>

    <script is:inline>
      (function () {
        var SUN = '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>';
        var MOON = '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
        var root = document.documentElement;
        function renderIcon() {
          var b = document.getElementById("theme-toggle");
          if (b) b.innerHTML = root.getAttribute("data-theme") === "dark" ? SUN : MOON;
        }
        document.getElementById("theme-toggle").addEventListener("click", function () {
          var next = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
          root.setAttribute("data-theme", next);
          try { localStorage.setItem("theme", next); } catch (e) {}
          renderIcon();
        });
        renderIcon();
      })();
    </script>
  </body>
</html>
